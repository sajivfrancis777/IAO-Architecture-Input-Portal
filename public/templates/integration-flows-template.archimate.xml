<?xml version="1.0" encoding="UTF-8"?>
<!--
  ADA Integration Flows Template — ArchiMate Open Exchange Format
  
  Compatible with: BiZZdesign Enterprise Studio, Archi, Sparx EA (ArchiMate import)
  
  USAGE:
    1. Import this file into your ArchiMate tool
    2. Add your elements (ApplicationComponent, Node, etc.) to the appropriate views
    3. Create Flow/Serving/Access relationships between source and target systems
    4. Export as ArchiMate Open Exchange (.xml) and upload via ADA Editor
  
  VIEW NAMING CONVENTION (parser detects these automatically):
    - "CurrentFlows(UNIVERSAL)"  → release=All,  state=Current
    - "FutureFlows(UNIVERSAL)"   → release=All,  state=Future
    - "R1_CurrentFlows"          → release=R1,   state=Current
    - "R1_FutureFlows"           → release=R1,   state=Future
    - ... through R5_CurrentFlows / R5_FutureFlows
  
  The parser extracts:
    - Source System = source element name
    - Target System = target element name  
    - Interface/Technology = relationship name (label your relationships!)
    
  TIPS:
    - Use ApplicationComponent for software systems (SAP S/4HANA, MuleSoft, etc.)
    - Use Node for infrastructure/hardware if needed
    - Use xsi:type="Flow" for data flows, xsi:type="Serving" for service calls
    - ALWAYS label relationships with the interface technology
    - You can add/rename views — parser detects R1-R9, Wave, Phase, etc.
    - Delete unused release views if not needed
-->
<model xmlns="http://www.opengroup.org/xsd/archimate/3.0/"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.opengroup.org/xsd/archimate/3.0/ http://www.opengroup.org/xsd/archimate/3.1/archimate3_Diagram.xsd"
       identifier="id-ada-template-001"
       version="1.0">
  
  <name xml:lang="en">ADA Integration Flows Template</name>
  
  <!-- ═══════════════════════════════════════════════════════════════
       ELEMENTS — Add your systems here as ApplicationComponent elements.
       Example elements shown below; replace with your actual systems.
       ═══════════════════════════════════════════════════════════════ -->
  <elements>
    <element identifier="id-elem-source-example" xsi:type="ApplicationComponent">
      <name xml:lang="en">Source System (replace me)</name>
      <documentation xml:lang="en">Replace with your source application name, e.g. SAP S/4HANA</documentation>
    </element>
    <element identifier="id-elem-target-example" xsi:type="ApplicationComponent">
      <name xml:lang="en">Target System (replace me)</name>
      <documentation xml:lang="en">Replace with your target application name, e.g. Snowflake PDH</documentation>
    </element>
    <element identifier="id-elem-middleware-example" xsi:type="ApplicationComponent">
      <name xml:lang="en">Middleware (replace me)</name>
      <documentation xml:lang="en">Replace with middleware name, e.g. MuleSoft Anypoint</documentation>
    </element>
  </elements>
  
  <!-- ═══════════════════════════════════════════════════════════════
       RELATIONSHIPS — Connect your systems here.
       The relationship NAME becomes "Interface / Technology" in the grid.
       ═══════════════════════════════════════════════════════════════ -->
  <relationships>
    <relationship identifier="id-rel-001" xsi:type="Flow"
                  source="id-elem-source-example" target="id-elem-middleware-example">
      <name xml:lang="en">IDoc (replace with actual interface technology)</name>
    </relationship>
    <relationship identifier="id-rel-002" xsi:type="Flow"
                  source="id-elem-middleware-example" target="id-elem-target-example">
      <name xml:lang="en">REST API (replace with actual interface technology)</name>
    </relationship>
  </relationships>
  
  <!-- ═══════════════════════════════════════════════════════════════
       VIEWS — Each view = one tab in the parser output.
       Name your views using the convention below.
       ═══════════════════════════════════════════════════════════════ -->
  <views>
    <diagrams>
      <!-- Universal Current State view -->
      <view identifier="id-view-current-univ" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">CurrentFlows(UNIVERSAL)</name>
        <documentation xml:lang="en">As-is integration landscape across all releases</documentation>
        <node identifier="id-vn-cu-01" elementRef="id-elem-source-example" x="100" y="200" w="160" h="80"/>
        <node identifier="id-vn-cu-02" elementRef="id-elem-target-example" x="500" y="200" w="160" h="80"/>
        <connection identifier="id-vc-cu-01" relationshipRef="id-rel-001" source="id-vn-cu-01" target="id-vn-cu-02"/>
      </view>
      
      <!-- Universal Future State view -->
      <view identifier="id-view-future-univ" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">FutureFlows(UNIVERSAL)</name>
        <documentation xml:lang="en">Overall target-state integration landscape across all releases</documentation>
        <node identifier="id-vn-fu-01" elementRef="id-elem-source-example" x="100" y="200" w="160" h="80"/>
        <node identifier="id-vn-fu-02" elementRef="id-elem-middleware-example" x="300" y="200" w="160" h="80"/>
        <node identifier="id-vn-fu-03" elementRef="id-elem-target-example" x="500" y="200" w="160" h="80"/>
        <connection identifier="id-vc-fu-01" relationshipRef="id-rel-001" source="id-vn-fu-01" target="id-vn-fu-02"/>
        <connection identifier="id-vc-fu-02" relationshipRef="id-rel-002" source="id-vn-fu-02" target="id-vn-fu-03"/>
      </view>
      
      <!-- R1 Current -->
      <view identifier="id-view-r1c" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R1_CurrentFlows</name>
        <documentation xml:lang="en">Release 1 current-state integration flows</documentation>
      </view>
      <!-- R1 Future -->
      <view identifier="id-view-r1f" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R1_FutureFlows</name>
        <documentation xml:lang="en">Release 1 future-state integration flows</documentation>
      </view>
      
      <!-- R2 Current -->
      <view identifier="id-view-r2c" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R2_CurrentFlows</name>
        <documentation xml:lang="en">Release 2 current-state integration flows</documentation>
      </view>
      <!-- R2 Future -->
      <view identifier="id-view-r2f" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R2_FutureFlows</name>
        <documentation xml:lang="en">Release 2 future-state integration flows</documentation>
      </view>
      
      <!-- R3 Current -->
      <view identifier="id-view-r3c" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R3_CurrentFlows</name>
        <documentation xml:lang="en">Release 3 current-state integration flows</documentation>
      </view>
      <!-- R3 Future -->
      <view identifier="id-view-r3f" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R3_FutureFlows</name>
        <documentation xml:lang="en">Release 3 future-state integration flows</documentation>
      </view>
      
      <!-- R4 Current -->
      <view identifier="id-view-r4c" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R4_CurrentFlows</name>
        <documentation xml:lang="en">Release 4 current-state integration flows</documentation>
      </view>
      <!-- R4 Future -->
      <view identifier="id-view-r4f" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R4_FutureFlows</name>
        <documentation xml:lang="en">Release 4 future-state integration flows</documentation>
      </view>
      
      <!-- R5 Current -->
      <view identifier="id-view-r5c" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R5_CurrentFlows</name>
        <documentation xml:lang="en">Release 5 current-state integration flows</documentation>
      </view>
      <!-- R5 Future -->
      <view identifier="id-view-r5f" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R5_FutureFlows</name>
        <documentation xml:lang="en">Release 5 future-state integration flows</documentation>
      </view>
    </diagrams>
  </views>
</model>
